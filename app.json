{
  "expo": {
    "name": "Verve",
    "slug": "verve",
    "scheme": "verve",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6758b7e5-f3b3-4e50-9f5b-81a6ed361d1f"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020408"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "lu.verve.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Verve needs access to your photos so you can set a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "lu.verve.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020408"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Verve needs access to your photos so you can set a profile picture."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "verve",
          "project": "verve-mobile"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#10B981",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6758b7e5-f3b3-4e50-9f5b-81a6ed361d1f"
      }
    }
  }
}
