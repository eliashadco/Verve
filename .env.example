# Verve mobile env file
# 1. Sign up at https://supabase.com (free tier)
# 2. Create a new project
# 3. Project Settings -> API: copy URL + anon key into the values below
# 4. Save this file as `.env` (no `.example`)
# 5. Restart Expo (`npm run start --clear`) so values reload

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional — error monitoring (P-4.4). Create a React Native project in Sentry and paste the DSN.
# EXPO_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# Set to 1 only when debugging the Sentry SDK itself.
# EXPO_PUBLIC_SENTRY_DEBUG=0

# For EAS Build source map upload, set SENTRY_AUTH_TOKEN as an EAS secret (never commit it).
# Match organization + project in app.json @sentry/react-native/expo plugin with your Sentry project.

# Temporary development shortcut: bypass auth and jump directly to one dashboard.
# Accepted values: client | trainer
# EXPO_PUBLIC_DEV_BYPASS_ROLE=client

# User Trial literal migration review mode:
# 1 => enable deterministic demo surfaces for non-MVP backend areas
# 0/undefined => disable demo fixtures and keep production behavior
# EXPO_PUBLIC_DEMO_USER_TRIAL=1

# Workout tab (web only): URL embedded as an iframe for the patient preview portal
# (the `frontend` Vite app). Defaults to the local dev server when unset.
# Set this to the deployed portal URL for production web builds.
# EXPO_PUBLIC_WORKOUT_PREVIEW_URL=http://localhost:5173/preview/patient
